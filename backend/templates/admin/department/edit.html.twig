{% extends 'base.html.twig' %}

{% block title %}Редактирование отдела {{ department.name }}{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item">
        <a class="link-body-emphasis fw-semibold text-decoration-none" href="{{ path('app_department_list') }}">Отделы</a>
    </li>
    <li class="breadcrumb-item active" aria-current="page">
        <a class="link-body-emphasis fw-semibold text-decoration-none" href="{{ path('app_department_show', { id : department.id }) }}">{{ department.name }}</a>
    </li>
    <li class="breadcrumb-item active" aria-current="page">Редактирование отдела </li>
{% endblock %}

{% block body %}
    <div class="card">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h4>Редактирование отдела</h4>
        </div>
        <div class="card-body">
            {% include('./admin/department/_partials/form.html.twig') with { form } %}
        </div>
    </div>
{% endblock %}
