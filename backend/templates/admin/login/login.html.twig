{% extends 'base-login.html.twig' %}

{% block body %}
<main class="form-signin w-100 m-auto">
    <form method="post">
        <h1 class="h3 mb-3 fw-normal">Авторизация</h1>
        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}
        <div class="form-floating">
            <input type="text" name="_username" value="{{ last_username }}" class="form-control" id="inputLogin" placeholder="Логин">
            <label for="inputLogin">Логин</label>
        </div>
        <div class="form-floating">
            <input type="password" name="_password" class="form-control" id="inputPassword" placeholder="Пароль">
            <label for="inputPassword">Пароль</label>
        </div>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <div class="form-check text-start my-3">
            <input class="form-check-input" type="checkbox" value="remember-me" id="checkDefault">
            <label class="form-check-label" for="checkDefault">Запомнить меня</label>
        </div>
        <button class="btn btn-primary w-100 py-2" type="submit">Войти</button>
        <p class="mt-5 mb-3 text-body-secondary">TaskTimer Admin © 2026</p>
    </form>
</main>
{% endblock %}
