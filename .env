PROJECT_NAME=tasktimer

# Актуальные версии на 2024/2025
POSTGRES_VERSION=17-alpine
REDIS_VERSION=7.4-alpine
NGINX_VERSION=stable-alpine
# PHP 8.4 — самый свежий стабильный релиз
PHP_VERSION=8.4-fpm-alpine
# Node 22 — текущая активная версия (Current)
NODE_VERSION=22-alpine
MERCURE_VERSION=latest

# Database
POSTGRES_DB=tasktimer
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# Ports
NGINX_PORT_LOCAL=80
NGINX_PORT_PROD=80
MERCURE_PORT=3001

# Mercure JWT Key (для WebSocket)
MERCURE_JWT_SECRET=!ChangeMeVerifyStrongKey123!